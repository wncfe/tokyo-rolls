# Example frontend env for Vite
# Copy to .env.local or set variables in your environment

VITE_API_URL=http://localhost:8000/api
# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_DADATA_API_KEY: DaData API key for address suggestions
# Register at https://dadata.ru → get free API key (10k requests/day)
VITE_DADATA_API_KEY="your_dadata_api_key_here"

# VITE_API_URL: Backend API URL
# For development: http://localhost:8000/api
# For production: your production backend URL
VITE_API_URL="http://localhost:8000/api"
