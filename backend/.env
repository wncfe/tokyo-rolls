# ==============================================================
# Tokyo Rolls — Environment Variables (copy to .env and fill in)
# ==============================================================
# Copy this file to .env or set environment variables in your deployment.
# Do NOT commit secrets. Provide your own values in CI or on the server.

# ─── Django ───
# Generate a secret key:  python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=your-very-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,tokyo-rolls.ru
DJANGO_CSRF_TRUSTED_ORIGINS=https://tokyo-rolls.ru
DJANGO_LOG_LEVEL=INFO

# ─── CORS (comma-separated origins for production) ───
# CORS_ALLOWED_ORIGINS=https://tokyo-rolls.ru

# ─── Database (SQLite by default; set DATABASE_URL for PostgreSQL) ───
# DATABASE_URL=postgres://user:password@db:5432/tokyorolls

# ─── Email (console backend in dev; SMTP in production) ───
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_EMAIL_HOST=smtp.yandex.ru
# DJANGO_EMAIL_PORT=465
# DJANGO_EMAIL_HOST_USER=noreply@tokyo-rolls.ru
# DJANGO_EMAIL_HOST_PASSWORD=your-password
# DJANGO_EMAIL_USE_TLS=False
# DJANGO_DEFAULT_FROM_EMAIL=noreply@tokyo-rolls.ru

# ─── YooKassa (online payments) ───
# Get Shop ID and Secret Key from https://yookassa.ru/my/
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://tokyo-rolls.ru/payment-result

# ─── DaData (address suggestions) ───
# Get API keys from https://dadata.ru/api/
DADATA_TOKEN=
DADATA_SECRET=

# ─── Docker (optional overrides) ───
# WEB_CONCURRENCY=4
# FORCE_RESEED=0
